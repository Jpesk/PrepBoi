# PrepPro Environment Variables
# Copy this file to .env and fill in your Supabase project credentials.
# These are baked in at BUILD TIME by Vite — never commit .env to source control.

# Supabase project URL (found in your Supabase dashboard > Settings > API)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon/public key (safe to use client-side — Row-Level Security enforces access)
VITE_SUPABASE_ANON_KEY=your-anon-key-here
